    "jsonwebtoken": "^9.0.2",
    "dayjs": "^1.11.11"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3",
    "pinia": "^2.1.7",
    "vite": "^5.3.1",
    "vue": "^3.4.30",
    "vue-router": "^4.4.0"
  }
}
