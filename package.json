{
  "name": "coffee-shop-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "小咖啡店日常记录工具",
  "scripts": {
    "dev:server": "nodemon server/app.js",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "start": "node server/app.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
